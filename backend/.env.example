PORT=8000
HOST=0.0.0.0

# Supabase PostgreSQL connection string
# Find this in: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Replace [PASSWORD] with your database password and [PROJECT-REF] with your project reference
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# For Supabase connection pooling (Transaction mode - recommended for serverless/edge):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

CORS_ORIGINS=["http://localhost:5173"]
