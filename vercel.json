{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://safemedesai.onrender.com/api/$1"
    },
    {
      "source": "/((?!assets/|logo.png|favicon.ico|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
